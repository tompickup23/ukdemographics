---
/**
 * Local asylum cost calculator.
 * Estimates what asylum support costs in this area based on:
 * - National hotel spend: £5.77M/day (£2.1B/year)
 * - National subsistence: £49.18/week per person
 * - Local authority grant: ~£1,200/year per dispersed person
 * - Local supported asylum seekers count
 * - Area households (for per-household figure)
 */
interface Props {
  areaName: string;
  supportedAsylum: number;
  totalHouseholds?: number;
  hotelSites?: number;
}

const { areaName, supportedAsylum, totalHouseholds, hotelSites = 0 } = Astro.props;

// National figures (Home Office / NAO)
const NATIONAL_HOTEL_DAILY = 5_770_000; // £5.77M/day (2024/25 average, NAO)
const NATIONAL_SUPPORTED_TOTAL = 107_003; // Total on support nationally
const SUBSISTENCE_WEEKLY = 49.18; // Per person per week
const LA_GRANT_ANNUAL = 1_200; // Per dispersed person per year

// Local estimates
const localSharePct = supportedAsylum / NATIONAL_SUPPORTED_TOTAL;
const localHotelDailyCost = Math.round(NATIONAL_HOTEL_DAILY * localSharePct);
const localHotelAnnualCost = localHotelDailyCost * 365;
const localSubsistenceAnnual = Math.round(supportedAsylum * SUBSISTENCE_WEEKLY * 52);
const localGrant = Math.round(supportedAsylum * LA_GRANT_ANNUAL);
const localTotalAnnual = localHotelAnnualCost + localSubsistenceAnnual;
const localPerHousehold = totalHouseholds && totalHouseholds > 0
  ? Math.round(localTotalAnnual / totalHouseholds)
  : null;

// National per-taxpayer
const TAXPAYERS = 34_100_000;
const nationalPerTaxpayer = Math.round(NATIONAL_HOTEL_DAILY * 365 / TAXPAYERS);

function fmt(n: number): string {
  if (n >= 1_000_000) return `£${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 1_000) return `£${(n / 1_000).toFixed(0)}K`;
  return `£${n.toLocaleString()}`;
}
---

{supportedAsylum > 0 && (
  <div class="cost-calc">
    <h3>What asylum costs {areaName}</h3>
    <div class="cost-grid">
      <div class="cost-item">
        <span class="cost-value">{fmt(localHotelAnnualCost)}</span>
        <span class="cost-label">estimated hotel costs/year</span>
      </div>
      <div class="cost-item">
        <span class="cost-value">{fmt(localSubsistenceAnnual)}</span>
        <span class="cost-label">subsistence payments/year</span>
      </div>
      <div class="cost-item">
        <span class="cost-value">{fmt(localGrant)}</span>
        <span class="cost-label">LA dispersal grant/year</span>
      </div>
      {localPerHousehold !== null && (
        <div class="cost-item cost-highlight">
          <span class="cost-value">£{localPerHousehold}</span>
          <span class="cost-label">per household/year</span>
        </div>
      )}
    </div>
    <p class="cost-note tiny">
      Estimates based on {supportedAsylum.toLocaleString()} people on asylum support in {areaName}
      ({(localSharePct * 100).toFixed(2)}% of {NATIONAL_SUPPORTED_TOTAL.toLocaleString()} nationally).
      Hotel costs pro-rated from £5.77M/day national spend (2024/25 average, NAO).
      Subsistence: £{SUBSISTENCE_WEEKLY}/week per person.
      {hotelSites > 0 ? ` ${hotelSites} known hotel sites in this area.` : ""}
      Nationally, the hotel bill alone costs £{nationalPerTaxpayer} per taxpayer per year.
    </p>
  </div>
)}

<style>
  .cost-calc {
    background: rgba(245, 158, 11, 0.04);
    border: 1px solid rgba(245, 158, 11, 0.15);
    border-radius: 10px;
    padding: 1.25rem;
    margin-top: 1.25rem;
  }
  .cost-calc h3 { font-size: 1rem; margin-bottom: 0.75rem; }
  .cost-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 0.75rem;
  }
  .cost-item {
    text-align: center;
    padding: 0.5rem;
    background: rgba(255,255,255,0.02);
    border-radius: 6px;
  }
  .cost-value {
    display: block;
    font-size: 1.4rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: #f59e0b;
  }
  .cost-label {
    display: block;
    font-size: 0.72rem;
    color: var(--muted);
    margin-top: 0.15rem;
  }
  .cost-highlight {
    background: rgba(245, 158, 11, 0.08);
    border: 1px solid rgba(245, 158, 11, 0.2);
  }
  .cost-highlight .cost-value { color: #ef4444; font-size: 1.6rem; }
  .cost-note { margin-top: 0.75rem; opacity: 0.5; }
</style>
