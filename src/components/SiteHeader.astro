---
const primaryNav = [
  { href: "/places", label: "Places" },
  { href: "/your-area", label: "Your Area" },
  { href: "/findings", label: "Research" },
  { href: "/national", label: "National" },
];

const moreNav = [
  { href: "/pressure", label: "Pressure Index" },
  { href: "/schools", label: "Schools" },
  { href: "/housing", label: "Housing" },
  { href: "/regional", label: "Regional" },
  { href: "/compare", label: "Compare" },
  { href: "/methodology", label: "Methodology" },
  { href: "/sources", label: "Sources" },
  { href: "/releases", label: "Releases" },
  { href: "/glossary", label: "Glossary" },
];

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(`${href}/`);
}
---

<header class="site-header shell">
  <a class="brand" href="/">
    <span class="brand-mark">
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" width="28" height="28" aria-hidden="true">
        <!-- UK Demographics — Population bars icon -->
        <rect x="3" y="18" width="5" height="11" rx="1.5" fill="#4f46e5"/>
        <rect x="10" y="12" width="5" height="17" rx="1.5" fill="#4f46e5" opacity="0.8"/>
        <rect x="17" y="7" width="5" height="22" rx="1.5" fill="#4f46e5" opacity="0.6"/>
        <rect x="24" y="3" width="5" height="26" rx="1.5" fill="#4f46e5" opacity="0.4"/>
        <!-- Trend line -->
        <path d="M5.5 17 L12.5 11 L19.5 6 L26.5 2" stroke="#818cf8" stroke-width="1.5" stroke-linecap="round" fill="none"/>
        <circle cx="5.5" cy="17" r="1.5" fill="#818cf8"/>
        <circle cx="26.5" cy="2" r="1.5" fill="#10b981"/>
      </svg>
    </span>
    <span class="brand-copy">
      <span>UK Demographics</span>
      <small>Population data for every community</small>
    </span>
  </a>

  <div class="site-tools">
    <button
      class="search-launch"
      type="button"
      data-site-search-open
      aria-haspopup="dialog"
      aria-controls="site-search-panel"
    >
      <span>Search</span>
      <span class="search-shortcut">/</span>
    </button>

    <!-- Desktop nav -->
    <nav class="site-nav desktop-nav" aria-label="Primary">
      {primaryNav.map((item) => (
        <a
          href={item.href}
          class="priority"
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
      <details class="more-dropdown">
        <summary class="more-trigger">More</summary>
        <div class="more-panel">
          {moreNav.map((item) => (
            <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          ))}
        </div>
      </details>
    </nav>

    <!-- Mobile hamburger -->
    <button class="mobile-menu-btn" type="button" data-mobile-menu-toggle aria-label="Open menu" aria-expanded="false">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>
</header>

<!-- Mobile drawer -->
<div class="mobile-drawer" data-mobile-drawer hidden>
  <div class="mobile-drawer-backdrop" data-mobile-drawer-close></div>
  <nav class="mobile-drawer-panel" aria-label="Mobile navigation">
    <div class="mobile-drawer-head">
      <span class="mobile-drawer-title">Menu</span>
      <button type="button" class="mobile-drawer-close" data-mobile-drawer-close aria-label="Close menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="mobile-drawer-links">
      <a href="/" class={pathname === "/" ? "active" : ""}>Home</a>
      {primaryNav.map((item) => (
        <a href={item.href} class={isActive(item.href) ? "active" : ""}>
          {item.label}
        </a>
      ))}
      <hr />
      {moreNav.map((item) => (
        <a href={item.href} class={isActive(item.href) ? "active" : ""}>
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</div>

<script>
  // Mobile drawer toggle
  const toggle = document.querySelector("[data-mobile-menu-toggle]");
  const drawer = document.querySelector("[data-mobile-drawer]");
  const closers = document.querySelectorAll("[data-mobile-drawer-close]");

  function openDrawer() {
    if (!drawer) return;
    drawer.removeAttribute("hidden");
    toggle?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }
  function closeDrawer() {
    if (!drawer) return;
    drawer.setAttribute("hidden", "");
    toggle?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  toggle?.addEventListener("click", openDrawer);
  closers.forEach((c) => c.addEventListener("click", closeDrawer));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !drawer?.hasAttribute("hidden")) closeDrawer();
  });
</script>

<!-- Site search (existing) -->
<div class="site-search-shell" data-site-search hidden inert aria-hidden="true">
  <div class="site-search-backdrop" data-site-search-close></div>
  <section
    id="site-search-panel"
    class="site-search-panel"
    data-site-search-panel
    role="dialog"
    aria-modal="true"
    aria-labelledby="site-search-title"
  >
    <div class="site-search-head">
      <div>
        <span class="tiny">Search the publication</span>
        <h2 id="site-search-title">Pages, regions, and place profiles</h2>
      </div>
      <button class="source-pill" type="button" data-site-search-close>Close</button>
    </div>

    <form class="site-search-form" role="search">
      <label class="filter-field">
        <span class="tiny">Search</span>
        <input
          type="search"
          name="site_search"
          placeholder="Try Birmingham, Burnley, North West, or an area code"
          autocomplete="off"
          spellcheck="false"
          data-site-search-input
        />
      </label>
    </form>

    <div class="site-search-meta">
      <span class="tiny" data-site-search-status>Loading search index...</span>
      <span class="tiny">Shortcut: <span data-site-search-hint>Ctrl+K</span></span>
    </div>

    <div class="site-search-results" data-site-search-results></div>
  </section>

  <script>
    import { initSiteSearch } from "../scripts/site-search";
    initSiteSearch();
  </script>
</div>

<style>
  /* More dropdown (desktop) */
  .more-dropdown {
    position: relative;
  }
  .more-trigger {
    cursor: pointer;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--muted);
    list-style: none;
    padding: 0.25rem 0.5rem;
    border-radius: 8px;
    transition: color 180ms;
  }
  .more-trigger:hover { color: var(--ink); }
  .more-trigger::-webkit-details-marker { display: none; }
  .more-trigger::after {
    content: "";
    display: inline-block;
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 4px solid currentColor;
    margin-left: 4px;
    vertical-align: middle;
  }
  .more-panel {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 180px;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 0.5rem;
    box-shadow: var(--shadow);
    z-index: 50;
    display: flex;
    flex-direction: column;
  }
  .more-panel a {
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    font-size: 0.85rem;
    color: var(--ink-soft);
    text-decoration: none;
    transition: background 180ms, color 180ms;
  }
  .more-panel a:hover {
    background: var(--panel-soft);
    color: var(--ink);
  }
  .more-panel a[aria-current="page"] {
    color: var(--accent);
    font-weight: 600;
  }

  /* Mobile menu button */
  .mobile-menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    background: none;
    color: var(--ink-soft);
    cursor: pointer;
    border-radius: 10px;
    transition: background 180ms;
  }
  .mobile-menu-btn:hover { background: var(--panel-soft); }

  @media (max-width: 900px) {
    .desktop-nav { display: none; }
    .mobile-menu-btn { display: flex; }
  }
</style>
