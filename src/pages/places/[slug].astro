---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import PlainEnglish from "../../components/PlainEnglish.astro";
import DataFreshness from "../../components/DataFreshness.astro";
import ShareButton from "../../components/ShareButton.astro";
import MpCard from "../../components/MpCard.astro";
import EthnicityTimeline from "../../components/EthnicityTimeline.astro";
import PageContents from "../../components/PageContents.astro";
import BenchmarkStrip from "../../components/BenchmarkStrip.astro";
import ProjectionChart from "../../components/ProjectionChart.astro";
import ScenarioSelector from "../../components/ScenarioSelector.astro";
import CostCalculator from "../../components/CostCalculator.astro";
import ShiftShareChart from "../../components/ShiftShareChart.astro";
import TrendChart from "../../components/TrendChart.astro";
import { buildSupportedAsylumStockDescription } from "../../lib/asylum-support-logic";
import { getAreaTrendSummary } from "../../lib/area-series";
import { getAreaRegionalPrimeProviderCoverage } from "../../lib/entity-analytics";
import { getEntityProfileByReference, getEntityProfiles } from "../../lib/entities";
import { loadLocalRouteLatest } from "../../lib/route-data";
import { loadHotelEntityLedger } from "../../lib/hotel-data";
import { buildAbsoluteUrl, buildPlaceStructuredData, getPublicPlaceAreas, slugifyAreaName } from "../../lib/site";
import {
  getEthnicProjection, getEthnicCompositionTimeline,
  getReligionData, getNativityData, getStochasticData,
  getShiftShareData, getDiversityIndex, getEnglishProficiency,
  getMigrationProfile, getSocioeconomicData
} from "../../lib/ethnic-projections";
import { getCrimeProfile, getCrimeRatePercentile } from "../../lib/crime-data";
import { getSendProfile, getSendGrowthPercentile } from "../../lib/send-data";
import { getAscProfile, getAscSpendPercentile } from "../../lib/asc-data";
import { computePressureScore } from "../../lib/pressure-index";
import { getMPsForArea } from "../../lib/mp-data";
import schoolValidationData from "../../data/live/school-validation.json";
import scenarioSummaries from "../../data/live/scenario-summaries.json";
import migrationEthnicity from "../../data/live/migration-ethnicity.json";
import schoolFertilityProxy from "../../data/live/school-fertility-proxy.json";
import {
  formatOrdinal,
  getDistributionStats,
  getPercentileRank
} from "../../lib/route-analytics";

const localRouteLatest = loadLocalRouteLatest();
const hotelLedger = loadHotelEntityLedger();

export function getStaticPaths() {
  return getPublicPlaceAreas().map((area) => ({
    params: { slug: slugifyAreaName(area.areaName) },
    props: { area }
  }));
}

const { area } = Astro.props;
const hotelSites = hotelLedger.sites.filter(
  (site) => site.areaCode === area.areaCode || site.areaName === area.areaName
);
const hotelArea = hotelLedger.areas.find(
  (a) => a.areaCode === area.areaCode || a.areaName === area.areaName
);
const currentHotelSites = hotelSites.filter((site) => site.status === "current");
const namedSiteCount = currentHotelSites.length;
const unnamedSiteCount = hotelArea?.unnamedSiteCount ?? 0;

const regionalAreas = [...localRouteLatest.areas]
  .filter((candidate) => candidate.regionName === area.regionName)
  .sort((a, b) => b.supportedAsylum - a.supportedAsylum);
const regionalRank = regionalAreas.findIndex((candidate) => candidate.areaCode === area.areaCode) + 1;
const regionalPeerRows = (() => {
  const leadingPeers = regionalAreas.slice(0, 5);
  if (leadingPeers.some((candidate) => candidate.areaCode === area.areaCode)) return leadingPeers;
  return [...leadingPeers, area];
})();

const areaRank =
  [...localRouteLatest.areas]
    .sort((a, b) => b.supportedAsylum - a.supportedAsylum)
    .findIndex((candidate) => candidate.areaCode === area.areaCode) + 1;
const contingencyRank =
  [...localRouteLatest.areas]
    .sort((a, b) => b.contingencyAccommodation - a.contingencyAccommodation)
    .findIndex((candidate) => candidate.areaCode === area.areaCode) + 1;

const pathwayBreakdown = [
  { label: "Supported asylum", value: area.supportedAsylum },
  { label: "Homes for Ukraine", value: area.homesForUkraineArrivals },
  { label: "Afghan programme", value: area.afghanProgrammePopulation },
  { label: "Resettlement cumulative", value: area.resettlementCumulativeTotal ?? 0 }
];
const maxPathwayValue = Math.max(...pathwayBreakdown.map((item) => item.value), 1);

const areaTrend = getAreaTrendSummary(area.areaCode);
const schoolValidation = (schoolValidationData as any).areas?.find((a: any) => a.areaCode === area.areaCode);

const regionalPrimeProviderCoverage = getAreaRegionalPrimeProviderCoverage(
  area, getEntityProfiles(), localRouteLatest.areas, hotelLedger.areas
);

const supportedStats = getDistributionStats(localRouteLatest.areas.map((c) => c.supportedAsylum));
const supportedRateStats = getDistributionStats(localRouteLatest.areas.map((c) => c.supportedAsylumRate ?? 0));
const contingencyStats = getDistributionStats(localRouteLatest.areas.map((c) => c.contingencyAccommodation));
const supportedPercentile = getPercentileRank(localRouteLatest.areas.map((c) => c.supportedAsylum), area.supportedAsylum);
const ratePercentile = getPercentileRank(localRouteLatest.areas.map((c) => c.supportedAsylumRate ?? 0), area.supportedAsylumRate ?? 0);
const contingencySharePct = area.supportedAsylum
  ? Number(((area.contingencyAccommodation / area.supportedAsylum) * 100).toFixed(1))
  : 0;
const supportedPercentileLabel = formatOrdinal(supportedPercentile);
const ratePercentileLabel = formatOrdinal(ratePercentile);
const regionalPeerMax = Math.max(...regionalPeerRows.map((c) => c.supportedAsylum), 1);

const ethnicProjection = getEthnicProjection(area.areaCode);
const ethnicTimeline = getEthnicCompositionTimeline(area.areaCode);
const wbThreshold = ethnicProjection?.thresholds.find((t) => t.label === "White British <50%") ?? null;
const significantShift = wbThreshold && wbThreshold.year <= 2070;
const religionData = getReligionData(area.areaCode);
const nativityData = getNativityData(area.areaCode);
const stochasticData = getStochasticData(area.areaCode);
const shiftShareData = getShiftShareData(area.areaCode);
const diversityIndex = getDiversityIndex(area.areaCode);
const englishProf = getEnglishProficiency(area.areaCode);
const migrationProfile = getMigrationProfile(area.areaCode);
const socioData = getSocioeconomicData(area.areaCode);

// Build ProjectionChart line data
const ethChartLines = ethnicTimeline ? (() => {
  const groups = ["white_british", "white_other", "asian", "black", "mixed", "other"] as const;
  const colors: Record<string, string> = { white_british: "#06b6d4", white_other: "#8b9cb3", asian: "#f59e0b", black: "#a78bfa", mixed: "#10b981", other: "#6b7280" };
  const labels: Record<string, string> = { white_british: "White British", white_other: "White Other", asian: "Asian", black: "Black", mixed: "Mixed", other: "Other" };
  return groups.filter(g => Math.max(...ethnicTimeline.map(t => t.groups[g])) > 3).map(g => ({
    label: labels[g], color: colors[g],
    points: ethnicTimeline.map(t => ({ year: Number(t.year), value: t.groups[g] }))
  }));
})() : [];

const ethConfidenceBand = stochasticData
  ? [2031, 2041, 2051].filter(y => stochasticData[y]).map(y => ({
      year: y, low: stochasticData[y].wbi.p10, high: stochasticData[y].wbi.p90
    }))
  : undefined;

const relChartLines = religionData ? (() => {
  const relGroups = [
    { key: "Christian", color: "#7dd3fc", label: "Christian" },
    { key: "No religion", color: "#6b7280", label: "No religion" },
    { key: "Muslim", color: "#f59e0b", label: "Muslim" },
    { key: "Hindu", color: "#a78bfa", label: "Hindu" },
    { key: "Sikh", color: "#10b981", label: "Sikh" }
  ];
  const years = [2021, 2031, 2041, 2051].filter(y => religionData[y]);
  return relGroups
    .filter(g => years.some(y => (religionData[y]?.[g.key] ?? 0) > 3))
    .map(g => ({ label: g.label, color: g.color, points: years.map(y => ({ year: y, value: religionData[y]?.[g.key] ?? 0 })) }));
})() : [];

const natChartLines = nativityData ? (() => {
  const years = [2021, 2031, 2041, 2051].filter(y => nativityData[y]);
  return [
    { label: "UK-born", color: "#06b6d4", points: years.map(y => ({ year: y, value: nativityData[y].ukBornPct })) },
    { label: "Foreign-born", color: "#f59e0b", points: years.map(y => ({ year: y, value: nativityData[y].foreignBornPct })) }
  ];
})() : [];
const crimeProfile = getCrimeProfile(area.areaCode);
const crimePercentile = getCrimeRatePercentile(area.areaCode);
const sendProfile = getSendProfile(area.areaCode);
const sendPercentile = getSendGrowthPercentile(area.areaCode);
const ascProfile = getAscProfile(area.areaCode);
const ascPercentile = getAscSpendPercentile(area.areaCode);
const pressureScore = computePressureScore(
  area.areaCode,
  area.areaName,
  area.supportedAsylumRate,
  localRouteLatest.areas.map((a) => a.supportedAsylumRate ?? 0)
);

// MP data
const areaMPs = getMPsForArea(area.areaName);
const primaryMP = areaMPs.length > 0 ? areaMPs[0] : null;

const pageDescription = `${area.areaName}: ${area.supportedAsylum.toLocaleString()} on asylum support, rank ${areaRank} nationally.${primaryMP ? ` MP: ${primaryMP.mpName} (${primaryMP.party}).` : ""} Hotels, demographics, crime, SEND, social care.`;
const pageStructuredData = buildPlaceStructuredData(area, {
  canonicalUrl: buildAbsoluteUrl(Astro.url.pathname),
  description: pageDescription,
  socialImageUrl: buildAbsoluteUrl(`/og/places/${slugifyAreaName(area.areaName)}.png`),
  snapshotDate: localRouteLatest.snapshotDate,
  areaRank,
  contingencyRank,
  namedSiteCount,
  unnamedSiteCount
});

const placeSections = [
  { id: "place-summary", label: "Summary" },
  ...(areaTrend ? [{ id: "recent-trend", label: "Trend" }] : []),
  { id: "local-numbers", label: "Local numbers" },
  ...(ethnicProjection ? [{ id: "tabpanel-demographics", label: "Demographics" }] : []),
  ...(socioData?.economicActivity ? [{ id: "tabpanel-economy", label: "Economy" }] : []),
  ...((crimeProfile || sendProfile || ascProfile) ? [{ id: "tabpanel-services", label: "Services" }] : []),
  { id: "tabpanel-benchmarks", label: "Benchmarks" }
];

function getSiteEntityProfiles(site: (typeof hotelSites)[number]) {
  const matches = [
    ...site.entityLinks.map((link) => getEntityProfileByReference(link.entityName, link.companyNumber)),
    site.primeProvider ? getEntityProfileByReference(site.primeProvider.provider, null) : null
  ].filter((profile): profile is NonNullable<typeof profile> => profile !== null && profile !== undefined);
  return [...new Map(matches.map((profile) => [profile.entityId, profile])).values()];
}
---

<BaseLayout
  title={`Asylum seekers in ${area.areaName} — ${area.supportedAsylum.toLocaleString()} on support | asylumstats`}
  description={pageDescription}
  structuredData={pageStructuredData}
>
  <!-- HEADER -->
  <Breadcrumbs items={[
    { label: "Places", href: "/places/" },
    { label: area.regionName, href: `/places/regions/${area.regionName.toLowerCase().replace(/\s+/g, "-")}/` },
    { label: area.areaName }
  ]} />

  <section class="page-top">
    <section class="page-head">
      <span class="kicker">{area.regionName}</span>
      <h1>{area.areaName}</h1>
      <div class="page-head-meta">
        <DataFreshness
          updated={localRouteLatest.snapshotDate ?? "2025-12-31"}
          source="Home Office"
          sourceUrl="https://www.gov.uk/government/statistics/immigration-system-statistics-year-ending-december-2025"
        />
        <ShareButton
          url={buildAbsoluteUrl(Astro.url.pathname)}
          title={`${area.areaName} - asylumstats`}
          text={`${area.areaName}: ${area.supportedAsylum.toLocaleString()} on asylum support, rank ${areaRank} nationally. See the full data.`}
          compact
        />
      </div>
    </section>

    <aside class="page-rail">
      <article class="panel panel-pad">
        <div class="stat-strip">
          <article class="stat-tile">
            <span class="tiny">UK rank</span>
            <strong>{areaRank.toLocaleString()}</strong>
          </article>
          <article class="stat-tile">
            <span class="tiny">On support</span>
            <strong>{area.supportedAsylum.toLocaleString()}</strong>
          </article>
          <article class="stat-tile">
            <span class="tiny">Rate /10k</span>
            <strong>{area.supportedAsylumRate ?? "n/a"}</strong>
          </article>
          <article class="stat-tile">
            <span class="tiny">Contingency</span>
            <strong>{area.contingencyAccommodation.toLocaleString()}</strong>
          </article>
          {wbThreshold && (
            <article class="stat-tile" style="border-left: 2px solid var(--coral);">
              <span class="tiny">WB minority by</span>
              <strong style="color: var(--coral);">~{wbThreshold.year}</strong>
            </article>
          )}
        </div>
      </article>
    </aside>
  </section>

  <!-- MP -->
  {primaryMP && (
    <section class="mp-section">
      <MpCard
        name={primaryMP.mpName}
        party={primaryMP.party}
        constituency={primaryMP.constituencyName}
        photoUrl={primaryMP.photoUrl ?? undefined}
      />
      {areaMPs.length > 1 && (
        <p class="mp-note">{areaMPs.length} MPs cover constituencies in or overlapping {area.areaName}.</p>
      )}
    </section>
  )}

  <PageContents title="Sections" sections={placeSections} />

  <!-- SUMMARY -->
  <section id="place-summary" class="section section-anchor">
    <PlainEnglish
      headline={`${area.supportedAsylum.toLocaleString()} people housed on asylum support in ${area.areaName}`}
      body={`Rank ${areaRank} of ${localRouteLatest.areas.length} councils nationally. The rate of ${area.supportedAsylumRate ?? "n/a"} per 10,000 puts ${area.areaName} in the ${ratePercentileLabel} percentile. That means ${ratePercentile >= 90 ? "this area carries more asylum seekers per head than 90% of the country" : ratePercentile >= 70 ? "this area carries more than most" : ratePercentile >= 30 ? "a moderate load compared to the national picture" : "fewer than most areas"}.${wbThreshold ? ` White British projected to be a minority by approximately ${wbThreshold.year}.` : ""}${area.contingencyAccommodation > 0 ? ` ${area.contingencyAccommodation.toLocaleString()} in contingency accommodation (hotels, not housing).` : ""} At roughly £150/person/day, that costs the taxpayer an estimated £${Math.round(area.supportedAsylum * 150 * 365 / 1_000_000)}M per year for this area alone.`}
      tone={ratePercentile >= 80 ? "alert" : ratePercentile >= 50 ? "info" : "success"}
    />
    <CostCalculator
      areaName={area.areaName}
      supportedAsylum={area.supportedAsylum}
      hotelSites={namedSiteCount + unnamedSiteCount}
    />
  </section>

  <!-- TREND -->
  {areaTrend && (
    <section id="recent-trend" class="split section section-anchor">
      <TrendChart
        points={areaTrend.points.map((point) => ({ label: point.label, value: point.value }))}
        title={areaTrend.deltaFromPrevious !== null && areaTrend.deltaFromPrevious > 0 ? `${area.areaName}: asylum numbers still rising` : areaTrend.deltaFromPrevious !== null && areaTrend.deltaFromPrevious < 0 ? `${area.areaName}: asylum numbers falling` : `${area.areaName}: asylum numbers holding steady`}
        description={buildSupportedAsylumStockDescription(areaTrend.latestPeriodLabel, areaTrend.hasIllustrativeData)}
        tone={(areaTrend.deltaFromPrevious ?? areaTrend.deltaFromFirst) > 0 ? "warm" : "teal"}
        annotations={[
          { label: "Rwanda scheme", pointLabel: "Jun 2022" },
          { label: "Albania deal", pointLabel: "Dec 2022" },
          { label: "Bibby Stockholm", pointLabel: "Sept 2023", color: "rgba(239,68,68,0.4)" },
          { label: "Rwanda scrapped", pointLabel: "Sept 2024", color: "rgba(239,68,68,0.5)" },
        ]}
      />
      <article class="panel panel-pad">
        <h2>Trend</h2>
        <div class="metric-list">
          <div class="metric-item">
            <span class="metric-value">
              {areaTrend.deltaFromPrevious !== null
                ? `${areaTrend.deltaFromPrevious >= 0 ? "+" : ""}${areaTrend.deltaFromPrevious.toLocaleString()}`
                : "—"}
            </span>
            <span class="metric-label">Latest quarter change</span>
          </div>
          <div class="metric-item">
            <span class="metric-value">
              {areaTrend.deltaFromFirst >= 0 ? "+" : ""}{areaTrend.deltaFromFirst.toLocaleString()}
            </span>
            <span class="metric-label">Change across series</span>
          </div>
          <div class="metric-item">
            <span class="metric-value">{areaTrend.officialAnchorCount}</span>
            <span class="metric-label">Official data points</span>
          </div>
        </div>
      </article>
    </section>
  )}

  <!-- LOCAL NUMBERS -->
  <section id="local-numbers" class="section section-anchor">
    <div class="section-head">
      <div>
        <h2>Local numbers</h2>
      </div>
    </div>
    <div class="grid-2">
      <article class="feature-card accent">
        <h3>Accommodation split</h3>
        <div class="data-list">
          <div class="data-row">
            <span>Dispersal accommodation</span>
            <span class="data-row-value">{area.dispersalAccommodation.toLocaleString()}</span>
          </div>
          <div class="data-row">
            <span>Initial accommodation</span>
            <span class="data-row-value">{area.initialAccommodation.toLocaleString()}</span>
          </div>
          <div class="data-row">
            <span>Subsistence only</span>
            <span class="data-row-value">{area.subsistenceOnly.toLocaleString()}</span>
          </div>
          <div class="data-row">
            <span>Contingency accommodation</span>
            <span class="data-row-value">{area.contingencyAccommodation.toLocaleString()}</span>
          </div>
        </div>
      </article>

      <article class="feature-card">
        <h3>Pathway breakdown</h3>
        {pathwayBreakdown.map((item) => (
          <div class="metric-bar">
            <div style="min-width: 10rem;">
              <strong>{item.label}</strong>
              <div class="tiny">{item.value.toLocaleString()}</div>
            </div>
            <div class="metric-track">
              <div class="metric-fill" style={`width: ${(item.value / maxPathwayValue) * 100}%`}></div>
            </div>
          </div>
        ))}
      </article>
    </div>

    <div class="grid-2" style="margin-top: 1rem;">
      <article class="feature-card">
        <h3>Other routes</h3>
        <div class="data-list">
          <div class="data-row">
            <span>Homes for Ukraine</span>
            <span class="data-row-value">{area.homesForUkraineArrivals.toLocaleString()}</span>
          </div>
          <div class="data-row">
            <span>Afghan programme</span>
            <span class="data-row-value">{area.afghanProgrammePopulation.toLocaleString()}</span>
          </div>
          <div class="data-row">
            <span>Resettlement cumulative</span>
            <span class="data-row-value">{(area.resettlementCumulativeTotal ?? 0).toLocaleString()}</span>
          </div>
        </div>
      </article>
      <article class="feature-card">
        <h3>Population context</h3>
        <div class="data-list">
          <div class="data-row">
            <span>All pathways total</span>
            <span class="data-row-value">{area.allThreePathwaysTotal.toLocaleString()}</span>
          </div>
          <div class="data-row">
            <span>Share of local population</span>
            <span class="data-row-value">{area.shareOfPopulationPct ?? "n/a"}%</span>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- ═══ TABBED SECTIONS ═══ -->
  <div class="place-tabs" data-tab-group>
    <div class="tab-bar" role="tablist">
      {ethnicProjection && <button role="tab" type="button" class="tab-btn" aria-selected="true" aria-controls="tabpanel-demographics" data-tab="demographics">Demographics</button>}
      {(socioData?.economicActivity || ethnicProjection?.schoolEthnicity) && <button role="tab" type="button" class="tab-btn" aria-selected={!ethnicProjection ? "true" : "false"} aria-controls="tabpanel-economy" data-tab="economy">Economy</button>}
      {(crimeProfile || sendProfile || ascProfile) && <button role="tab" type="button" class="tab-btn" aria-selected="false" aria-controls="tabpanel-services" data-tab="services">Services</button>}
      <button role="tab" type="button" class="tab-btn" aria-selected="false" aria-controls="tabpanel-benchmarks" data-tab="benchmarks">Benchmarks</button>
    </div>

    <!-- HOTELS REMOVED - insufficient place-specific data -->

    <!-- TAB: Demographics (default/first) -->
    <div id="tabpanel-demographics" role="tabpanel" class="tab-panel" data-tab-panel="demographics">

  {ethnicProjection && ethChartLines.length > 0 && (
    <section id="demographic-profile" class="section section-anchor">
      <div class="section-head">
        <div>
          <h2>Ethnic composition projection</h2>
          <p class="lede">
            {area.areaName}: WBI {ethnicProjection.current.groups.white_british.toFixed(1)}% (2021)
            → {ethnicProjection.projections?.["2051"]?.white_british?.toFixed(1) ?? "?"}% (2051).
            {wbThreshold ? ` White British minority by ~${wbThreshold.year}.` : ""}
            {stochasticData?.[2051] ? ` 80% CI: ${stochasticData[2051].wbi.p10}–${stochasticData[2051].wbi.p90}%.` : ""}
          </p>
        </div>
      </div>
      <ProjectionChart
        title={`Ethnic composition - ${area.areaName}`}
        lines={ethChartLines}
        confidenceBand={ethConfidenceBand}
        nowYear={2021}
        yLabel="% of population"
      />
      {ethnicTimeline && ethnicTimeline.length > 0 && (
        <div style="margin-top: 1.25rem;">
          <EthnicityTimeline timeline={ethnicTimeline} areaName={area.areaName} />
        </div>
      )}
      <details class="method-note" style="margin-top: 0.5rem;">
        <summary class="tiny" style="cursor: pointer; opacity: 0.6;">Model: Hamilton-Perry single-year CCRs, 1,000 Monte Carlo simulations, SNPP-constrained</summary>
        <p class="tiny" style="margin-top: 0.4rem; opacity: 0.5;">
          Census 2011 to 2021 cohort change ratios. Shaded band = 80% confidence interval from stochastic perturbation. Not a forecast.
        </p>
      </details>

      {scenarioSummaries?.areas?.[area.areaCode] && (
        <ScenarioSelector
          areaCode={area.areaCode}
          areaName={area.areaName}
          scenarioData={scenarioSummaries.areas[area.areaCode]}
          centralScenario={scenarioSummaries.centralScenario}
        />
      )}
    </section>
  )}

  <!-- RELIGION -->
  <!-- RELIGION - ProjectionChart -->
  {religionData && relChartLines.length > 0 && (
    <section id="religion-profile" class="section section-anchor">
      <div class="section-head">
        <div>
          <h2>Religion projection</h2>
          <p class="lede">
            Muslim {religionData[2021]?.Muslim?.toFixed(1)}% (2021) → {religionData[2051]?.Muslim?.toFixed(1)}% (2051).
            Christian {religionData[2021]?.Christian?.toFixed(1)}% → {religionData[2051]?.Christian?.toFixed(1)}%.
          </p>
        </div>
      </div>
      <ProjectionChart title={`Religion - ${area.areaName}`} lines={relChartLines} nowYear={2021} yLabel="%" />
    </section>
  )}

  <!-- NATIVITY -->
  <!-- NATIVITY - ProjectionChart -->
  {nativityData && natChartLines.length > 0 && (
    <section id="nativity-profile" class="section section-anchor">
      <div class="section-head">
        <div>
          <h2>Nativity</h2>
          <p class="lede">
            {nativityData[2021] ? `${nativityData[2021].foreignBornPct}% foreign-born (2021).` : ""}
            {diversityIndex ? ` Diversity: ${diversityIndex.diversityLevel} (entropy ${diversityIndex.entropy}).` : ""}
            {englishProf ? ` ${englishProf.mainLanguageEnglishPct}% main language English.` : ""}
          </p>
        </div>
      </div>
      <ProjectionChart title={`UK-born vs foreign-born - ${area.areaName}`} lines={natChartLines} nowYear={2021} yLabel="%" height={180} />
      {migrationProfile && (
        <p class="tiny" style="margin-top: 0.5rem; opacity: 0.5;">
          {migrationProfile.maturityLevel}: {migrationProfile.implication}
        </p>
      )}
      {(migrationEthnicity as any)?.areas?.[area.areaCode] && (() => {
        const mig = (migrationEthnicity as any).areas[area.areaCode];
        const groups = mig.groups || {};
        return (
          <details class="method-note" style="margin-top: 0.5rem;">
            <summary class="tiny" style="cursor: pointer; opacity: 0.6;">
