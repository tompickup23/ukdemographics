---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import DataFreshness from "../../../components/DataFreshness.astro";
import PlainEnglish from "../../../components/PlainEnglish.astro";
import { slugifyAreaName } from "../../../lib/site";
import { getPlaceDirectory, type PlaceDirectoryRegion } from "../../../lib/place-directory";
import { loadLocalRouteLatest } from "../../../lib/route-data";
import rawProjections from "../../../data/live/ethnic-projections.json";

const localRouteLatest = loadLocalRouteLatest();

export function getStaticPaths() {
  return getPlaceDirectory().regions.map((region) => ({
    params: { region: region.regionSlug },
    props: { region }
  }));
}

const { region } = Astro.props as { region: PlaceDirectoryRegion };

// Sort areas by asylum support (descending)
const areasSorted = [...region.areas].sort((a, b) => b.area.supportedAsylum - a.area.supportedAsylum);
const maxAreaAsylum = areasSorted[0]?.area.supportedAsylum ?? 1;
const totalRegional = region.supportedAsylum;

// Compute regional WBI
const allAreas = (rawProjections as any).areas as Record<string, any>;
let wbiSum2021 = 0, wbiSum2051 = 0, wbiCount = 0;
for (const row of region.areas) {
  const proj = allAreas[row.area.areaCode];
  if (!proj?.current?.groups?.white_british) continue;
  wbiSum2021 += proj.current.groups.white_british;
  wbiSum2051 += proj.projections?.["2051"]?.white_british ?? proj.current.groups.white_british;
  wbiCount++;
}
const regionWbi2021 = wbiCount > 0 ? wbiSum2021 / wbiCount : null;
const regionWbi2051 = wbiCount > 0 ? wbiSum2051 / wbiCount : null;

const pageDescription = `${region.regionName}: ${totalRegional.toLocaleString()} asylum seekers on support across ${region.areas.length} local authorities. Rate: ${region.supportedAsylumRate?.toFixed(1)} per 10,000.`;
---

<BaseLayout
  title={`${region.regionName} | asylumstats`}
  description={pageDescription}
>
  <Breadcrumbs items={[
    { label: "Places", href: "/places/" },
    { label: "Regional", href: "/regional/" },
    { label: region.regionName }
  ]} />

  <section class="page-top">
    <section class="page-head">
      <span class="kicker">{region.countryName}</span>
      <h1>{region.regionName}</h1>
      <DataFreshness
        updated={localRouteLatest.snapshotDate ?? "2025-12-31"}
        source="Home Office"
        sourceUrl="https://www.gov.uk/government/statistics/immigration-system-statistics-year-ending-december-2025"
      />
    </section>
    <aside class="page-rail">
      <article class="panel panel-pad">
        <div class="stat-strip">
          <article class="stat-tile">
            <span class="tiny">On support</span>
            <strong>{totalRegional.toLocaleString()}</strong>
          </article>
          <article class="stat-tile">
            <span class="tiny">Rate /10k</span>
            <strong>{region.supportedAsylumRate?.toFixed(1) ?? "-"}</strong>
          </article>
          <article class="stat-tile">
            <span class="tiny">Areas</span>
            <strong>{region.areas.length}</strong>
          </article>
          {regionWbi2021 !== null && (
            <article class="stat-tile">
              <span class="tiny">WBI 2051</span>
              <strong>{regionWbi2051?.toFixed(0)}%</strong>
            </article>
          )}
        </div>
      </article>
    </aside>
  </section>

  <PlainEnglish
    headline={`${totalRegional.toLocaleString()} people on asylum support in ${region.regionName}`}
    body={`${region.areas.length} local authorities in this region. Rate of ${region.supportedAsylumRate?.toFixed(1) ?? "-"} per 10,000 residents.${regionWbi2021 !== null ? ` Average White British share: ${regionWbi2021.toFixed(0)}% (2021) projected to ${regionWbi2051?.toFixed(0)}% by 2051.` : ""} At roughly £150/person/day, asylum support in this region alone costs an estimated £${Math.round(totalRegional * 150 * 365 / 1_000_000)}M per year.`}
    tone={totalRegional > 10000 ? "alert" : totalRegional > 3000 ? "info" : "success"}
  />

  <!-- AREA RANKING -->
  <section class="section shell">
    <h2 class="reg-section-title">Local authorities ranked by asylum seekers on support</h2>
    <div class="reg-area-list">
      {areasSorted.map((row, i) => {
        const a = row.area;
        const pct = (a.supportedAsylum / maxAreaAsylum) * 100;
        const proj = allAreas[a.areaCode];
        const wbiNow = proj?.current?.groups?.white_british;
        const wbi51 = proj?.projections?.["2051"]?.white_british;
        return (
          <a href={`/places/${slugifyAreaName(a.areaName)}/`} class="reg-area-row">
            <span class="reg-area-rank">{i + 1}</span>
            <div class="reg-area-info">
              <span class="reg-area-name">{a.areaName}</span>
              <span class="reg-area-bar-track">
                <span class="reg-area-bar-fill" style={`width: ${pct}%`}></span>
              </span>
            </div>
            <span class="reg-area-count">{a.supportedAsylum.toLocaleString()}</span>
            <span class="reg-area-rate">{a.supportedAsylumRate?.toFixed(1) ?? "-"}</span>
            {wbiNow !== undefined && (
              <span class="reg-area-wbi">{wbiNow.toFixed(0)}% → {wbi51?.toFixed(0) ?? "?"}%</span>
            )}
          </a>
        );
      })}
    </div>
    <p class="reg-area-caption">
      Click any area for the full profile. Rate = per 10,000 residents. WBI = White British Index (2021 → 2051 projected).
    </p>
  </section>
</BaseLayout>

<style>
  .reg-section-title {
    font-family: "Sora", sans-serif;
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--ink);
    margin: 0 0 1rem;
  }
  .reg-area-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .reg-area-row {
    display: grid;
    grid-template-columns: 28px 1fr 70px 55px 90px;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0;
    text-decoration: none;
    color: var(--ink);
    border-bottom: 1px solid var(--border);
    transition: background 120ms;
  }
  .reg-area-row:hover {
    background: rgba(6, 182, 212, 0.04);
  }
  .reg-area-rank {
    font-family: "Sora", sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--muted);
    text-align: center;
  }
  .reg-area-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }
  .reg-area-name {
    font-size: 0.88rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .reg-area-bar-track {
    display: block;
    height: 8px;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 4px;
    overflow: hidden;
  }
  .reg-area-bar-fill {
    display: block;
    height: 100%;
    background: linear-gradient(90deg, var(--accent), rgba(6, 182, 212, 0.3));
    border-radius: 4px;
    min-width: 2px;
  }
  .reg-area-count {
    font-family: "Sora", sans-serif;
    font-size: 0.88rem;
    font-weight: 800;
    color: var(--accent);
    text-align: right;
  }
  .reg-area-rate {
    font-size: 0.82rem;
    color: var(--muted);
    text-align: right;
  }
  .reg-area-wbi {
    font-size: 0.78rem;
    color: var(--muted);
    text-align: right;
    white-space: nowrap;
  }
  .reg-area-caption {
    font-size: 0.78rem;
    color: var(--muted);
    opacity: 0.5;
    margin-top: 0.75rem;
  }

  @media (max-width: 640px) {
    .reg-area-row {
      grid-template-columns: 24px 1fr 55px 45px;
      gap: 0.3rem;
    }
    .reg-area-wbi { display: none; }
    .reg-area-name { font-size: 0.82rem; }
    .reg-area-count { font-size: 0.82rem; }
  }
</style>
